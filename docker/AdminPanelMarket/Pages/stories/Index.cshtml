@page
@model AdminPanelMarket.Pages.stories.IndexModel

@{
    ViewData["Title"] = "Сторисы";
}

<h1>Сторисы</h1>

<p>
    <a asp-page="Create">Добавить новую сторис</a>
</p>
<div class="row">
    <div class="col">
        <div class="input-group mb-3">
          <span class="input-group-text" id="basic-addon1">🔍</span>
          <input type="text" class="form-control search-input" placeholder="Поиск...">
        </div>
    </div>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                Изображение
            </th>
            <th>
                Текст
            </th>
            <th>
                Дата
            </th>
            <th>
                Ссылка
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Stories) {
        <tr>
            <td>
                <img class="image-enter" src="https://backend.hozyainduhi.ru/api/Categories/image/@item.Color">
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Text)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Date)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Url)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Редактировать</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Удалить</a>
            </td>
        </tr>
}
    </tbody>
</table>
<script>
    $(".search-input").on("keyup", function() {
        var value = $(this).val().toLowerCase();
        $(".table tr").filter(function() {
            $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
        });
    });

    // Если поле поиска пустое, показываем все записи
    $(".search-input").on("input", function() {
        if ($(this).val().trim() === "") {
            $(".table tr").show();
        }
    });
</script>
