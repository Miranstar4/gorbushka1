@page
@model AdminPanelMarket.Pages.stories.DeleteModel

@{
    ViewData["Title"] = "Удалить";
}

<h1>Удаление</h1>

<h3>Вы действительно хотите удалить?</h3>
<div>
    <h4>Сторис</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Текст
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model._Story.Text)
        </dd>
        <dt class="col-sm-2">
            Ссылка
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model._Story.Url)
        </dd>
        <dt class="col-sm-2">
            Дата
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model._Story.Date)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="_Story.Id" />
        <input type="submit" value="Удалить" class="btn btn-danger" /> |
        <a asp-page="./Index">Вернутся назад</a>
    </form>
</div>
