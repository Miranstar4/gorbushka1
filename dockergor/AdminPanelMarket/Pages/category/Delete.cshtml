@page
@model AdminPanelMarket.Pages.category.DeleteModel

@{
    ViewData["Title"] = "Удалить категорию " + Model.Category.Name;
}

<h1>Удалить категорию</h1>

<h3>Вы действительно хотите удалить?</h3>
<div>
    <h4>Категория</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Наименование
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Category.Name)
        </dd>
        <dt class="col-sm-2">
            Картинка
        </dt>
        <dd class="col-sm-10">
            <img class="image-enter" src="https://backend.hozyaintelegram.ru/api/Categories/image/@Model.Category.Image">
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Category.Id" />
        <input type="submit" value="Удалить" class="btn btn-danger" /> |
        <a asp-page="./Index">Вернутся назад</a>
    </form>
</div>
